# Copy to .env on the SERVER ONLY (never commit the real file — it holds
# secrets). server-setup.sh generates this for you automatically on first
# run; this file just documents what ends up in it.

POSTGRES_USER=dayclaim_ar
POSTGRES_PASSWORD=change-me

REDIS_PASSWORD=change-me

RABBITMQ_USER=dayclaim_ar
RABBITMQ_PASSWORD=change-me

# openssl rand -base64 48
JWT_SIGNING_KEY=change-me-to-a-random-32-byte-or-longer-string

# openssl rand -base64 32   (must decode to exactly 32 bytes each, and must differ from one another)
ENCRYPTION_DATA_KEY=change-me-base64-32-bytes
ENCRYPTION_BLIND_INDEX_KEY=change-me-base64-32-bytes

# Origin the frontend is served from — the API's CORS allow-list.
PUBLIC_ORIGIN=http://137.23.41.70

# Seed the well-known Admin/Admin@123 demo account on first boot. Flip to
# "false" once you've created real accounts and no longer want it.
SEED_DEMO_DATA=true
